{
	"name": "@any-tdf/react-confetti",
	"version": "0.0.0-alpha.0",
	"description": "React port of svelte-confetti's pure HTML and CSS confetti effect.",
	"type": "module",
	"license": "MIT",
	"sideEffects": false,
	"homepage": "https://github.com/any-tdf/any-tdf/tree/main/react-confetti#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/any-tdf/any-tdf",
		"directory": "react-confetti"
	},
	"bugs": {
		"url": "https://github.com/any-tdf/any-tdf/issues"
	},
	"keywords": ["react", "confetti", "svelte-confetti", "css animation", "ssr"],
	"files": ["dist", "README.md", "LICENSE"],
	"scripts": {
		"build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
		"docs:build": "bun run --cwd docs/site build",
		"docs:dev": "bun run --cwd docs/site dev",
		"docs:preview": "bun run --cwd docs/site preview",
		"test": "bun test"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.1.4",
		"@types/react-dom": "^19.1.5",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "^5.8.3"
	}
}
